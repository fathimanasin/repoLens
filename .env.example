# PostgreSQL
POSTGRES_DB=repolens
POSTGRES_USER=repolens
POSTGRES_PASSWORD=replace_with_secure_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://repolens:replace_with_secure_password@localhost:5432/repolens?schema=public

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_secure_password
NEO4J_URI=bolt://localhost:7687
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# Backend
NODE_ENV=development
PORT=3001
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace_with_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
GITHUB_CLIENT_ID=github_oauth_client_id
GITHUB_CLIENT_SECRET=github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# Analysis worker
ANALYSIS_WORKER_PORT=8001
OPENAI_API_KEY=sk-placeholder

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=/api
